{
	"name": "vuejs",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "vite --mode modern --base ''",
		"build": "run-p  \"build-only {@}\" --",
		"preview:modern": "vite preview --mode modern --base ''",
		"preview:legacy": "vite preview --mode legacy --base ''",
		"build-only:modern": "vite build --mode modern",
		"build-only:legacy": "vite build --mode legacy && npx babel dist/legacy/assets --out-dir dist/legacy/assets --ignore \"*.css\",\"**/es5.js\"",
		"build-only": "npm run build-only:modern && npm run build-only:legacy && npm run postbuild",
		"build-loader": "npx babel src/loader.ts --out-file dist/legacy/assets/loader.js --extensions \".ts\"",
		"postbuild": "npm run build-loader && cp index-build.html dist/index.html",
		"type-check": "vue-tsc --noEmit -p tsconfig.app.json --composite false",
		"lint": "eslint src",
		"lint-fix": "eslint --fix src",
		"format": "prettier --write src"
	},
	"dependencies": {
		"@codemirror/lang-go": "^6.0.1",
		"@codemirror/lang-html": "^6.4.9",
		"@codemirror/lang-json": "^6.0.1",
		"@codemirror/lang-markdown": "^6.3.2",
		"@codemirror/theme-one-dark": "^6.1.2",
		"@dagrejs/dagre": "^3.0.0",
		"@embedpdf/vue-pdf-viewer": "^2.14.4",
		"@floating-ui/vue": "^1.1.11",
		"@headlessui/vue": "^1.7.23",
		"@tiptap/extension-color": "^2.11.7",
		"@tiptap/extension-link": "^2.27.2",
		"@tiptap/extension-list-item": "^2.11.7",
		"@tiptap/extension-text-style": "^2.11.7",
		"@tiptap/extension-underline": "^2.11.7",
		"@tiptap/pm": "^2.11.7",
		"@tiptap/starter-kit": "^2.11.7",
		"@tiptap/vue-3": "^2.11.7",
		"@vue-flow/background": "^1.3.2",
		"@vue-flow/core": "^1.48.2",
		"apexcharts": "^5.16.0",
		"codemirror": "^6.0.1",
		"crawler-user-agents": "^1.44.0",
		"pinia": "^3.0.1",
		"qrcode": "^1.5.4",
		"sanitize-html": "^2.15.0",
		"uuid": "^14.0.0",
		"vue": "^3.5.40",
		"vue-codemirror": "^6.1.1",
		"vue-i18n": "^10.0.6",
		"vue-qrcode-reader": "^5.7.2",
		"vue-router": "^4.3.0",
		"vue3-apexcharts": "^1.11.1",
		"weeknumber": "^1.2.1"
	},
	"devDependencies": {
		"@babel/cli": "^7.28.3",
		"@babel/core": "^7.28.3",
		"@babel/plugin-transform-modules-commonjs": "^7.27.1",
		"@babel/plugin-transform-modules-umd": "^7.27.1",
		"@babel/preset-env": "^7.28.3",
		"@babel/preset-typescript": "^7.27.1",
		"@eslint/js": "^10.0.1",
		"@tailwindcss/typography": "^0.5.16",
		"@types/node": "^20.12.3",
		"@types/qrcode": "^1.5.5",
		"@types/sanitize-html": "^2.15.0",
		"@types/uuid": "^9.0.8",
		"@vitejs/plugin-vue": "^6.0.8",
		"@vue/test-utils": "^2.4.5",
		"autoprefixer": "^10.4.19",
		"bowser": "^2.12.0",
		"core-js": "^3.45.1",
		"core-js-bundle": "^3.45.1",
		"es5-polyfill": "^0.0.6",
		"eslint": "^10.4.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-vue": "^10.9.2",
		"globals": "^17.6.0",
		"jiti": "^2.7.0",
		"postcss": "^8.4.38",
		"prettier": "^3.8.3",
		"regenerator-runtime": "^0.14.1",
		"rollup-plugin-visualizer": "^6.0.3",
		"tailwindcss": "^3.4.3",
		"terser": "^5.43.1",
		"typescript": "~5.4.3",
		"typescript-eslint": "^8.60.1",
		"vite": "^8.1.5",
		"vite-plugin-static-copy": "^3.1.2",
		"vite-plugin-vue-devtools": "^8.0.3",
		"vite-svg-loader": "^5.1.0",
		"vue-eslint-parser": "^10.4.1",
		"vue-tsc": "^2.0.7"
	}
}
